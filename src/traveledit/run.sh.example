#!/bin/bash

GO111MODULE=off \
GOPATH=$(pwd)/../.. \
go build -o traveledit || exit 1

GO111MODULE=off \
GOPATH=$(pwd)/../.. \
BASICUSER=user1 \
BASICPASS=somepw \
SCREENSHARENOAUTH= \
PUBLICPATH="../../../public" \
./traveledit \
-location=/ \
-proxypath=/yourproxypath \
-proxypathtrimmed=false \
-addr=:8080



